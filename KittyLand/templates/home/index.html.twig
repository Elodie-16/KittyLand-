{% extends 'base.html.twig' %}

{% block title %}Accueil — KittyLand{% endblock %}

{% block body %}

<header class="navbar">
    <div class="logo">🎀</div>
    
    <div class="search-box">
        <input type="search" placeholder="Recherche...">
        <span class="search-icon">🔍</span>
    </div>
    
    <nav>
        <a href="#">Accueil</a>
        <a href="#">Gallerie</a>
        <a href="#">billetterie</a>
        <a href="#">KittyClub</a>
        <button class="btn-connexion">connexion</button>
        <button class="btn-inscription">inscription</button>
    </nav>
</header>

<main>
    <div class="filters">
        <button class="active">Tout</button>
        <button>Piscine</button>
        <button>Hotel</button>
        <button>Parc d'attraction</button>
    </div>

    <section class="grid-container">
        <article class="card card-small"><img src="img1.jpg" alt=""><h3>Plage</h3><p>5€</p></article>
        <article class="card card-small"><img src="img2.jpg" alt=""><h3>Reception</h3><p>5€</p></article>
        <article class="card card-small"><img src="img3.jpg" alt=""><h3>Chambre</h3><p>15€</p></article>
        <article class="card card-small"><img src="img4.jpg" alt=""><h3>Cocktail</h3><p>20€</p></article>

        <article class="card card-large"><img src="img5.jpg" alt=""><h3>Hotel & piscine</h3><p>150€</p></article>
        <article class="card card-large"><img src="img6.jpg" alt=""><h3>Restaurant</h3><p>100€</p></article>
    </section>

    <section class="testimonials">
        <div class="user-card"><div class="avatar">L</div><h4>Lea Herden</h4><div class="stars">★★★★☆</div></div>
        <div class="user-card"><div class="avatar">E</div><h4>Emily Dupont</h4><div class="stars">★★★★☆</div></div>
        <div class="user-card"><div class="avatar">A</div><h4>Alice Unicorn</h4><div class="stars">★★★★★</div></div>
    </section>
</main>

<footer class="main-footer">
    <p>📍 Ile de la pastel, 2942 | 📞 01 82 12 05 16</p>
    <nav>
        <a href="#">Mentions Legal</a>
        <a href="#">Condition General</a>
        <a href="#">Aide & Service</a>
    </nav>
</footer>

{% endblock %}